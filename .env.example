# Database
DATABASE_URL=postgresql://user:password@localhost:5432/minhaagendaai
DB_SSL_REJECT_UNAUTHORIZED=false  # Set to true in production

# Redis
REDIS_URL=redis://localhost:6379

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=sk-...

# Encryption
ENCRYPTION_KEY=your-32-byte-hex-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SOLO=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...
STRIPE_CREDIT_BASIC=price_...
STRIPE_CREDIT_PRO=price_...
STRIPE_CREDIT_PREMIUM=price_...

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://your-evolution-api.com
EVOLUTION_API_KEY=your-api-key

# Admin & Cron Security
ADMIN_API_KEY=your-admin-key
CRON_SECRET=your-cron-secret

# AI Settings (optional)
AI_DEBUG=false
AI_HISTORY_LIMIT=10
AI_TIMEOUT_MS=90000

# Rate Limiting (optional)
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_SECONDS=60

# Logging (optional)
LOG_LEVEL=info
