{
  "buildCommand": "pnpm build",
  "outputDirectory": ".next",
  "installCommand": "pnpm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/marketing-dispatcher",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/google-calendar-sync",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/retention-audit",
      "schedule": "0 9 * * *"
    }
  ]
}

