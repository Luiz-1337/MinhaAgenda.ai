{
  "name": "@repo/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tools/vercel-ai": {
      "types": "./tools/vercel-ai.ts",
      "import": "./tools/vercel-ai.ts",
      "default": "./tools/vercel-ai.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:flow": "cross-env TEST_TRACE=1 vitest --run --reporter=verbose"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@repo/db": "workspace:*",
    "google-auth-library": "^9.0.0",
    "googleapis": "^144.0.0",
    "uuid": "^9.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^7.0.3",
    "@types/node": "^20.11.24",
    "@types/uuid": "^9.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  }
}
